{
  "name": "flipper12-backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Central nervous system of Flipper 12: game engine, MQTT bridge, WebSocket gateway, persistence, Solana",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "node --test --experimental-strip-types \"tests/**/*.test.ts\"",
    "format": "prettier --write \"**/*.{ts,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,json,md}\""
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "prettier": "^3.8.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@fastify/websocket": "^11.2.0",
    "cannon-es": "^0.20.0",
    "fastify": "^5.8.4",
    "ioredis": "^5.10.1",
    "mqtt": "^5.15.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.9",
    "zod": "^4.3.6"
  }
}
