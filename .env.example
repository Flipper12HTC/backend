# Serveur HTTP
PORT=8080
HOST=0.0.0.0

# Logger
LOG_LEVEL=info
NODE_ENV=development

# MQTT
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_CLIENT_ID=flipper12-backend

# PostgreSQL
DATABASE_URL=postgresql://flipper:flipper@localhost:5432/flipper12

# Redis
REDIS_URL=redis://localhost:6379

# Solana
# PAYMENT_GATEWAY=solana -> real devnet | fake -> in-memory (offline dev, no SOL needed)
PAYMENT_GATEWAY=fake
# For fake gateway only: auto-confirm payments instantly (handy for demos)
PAYMENT_AUTOCONFIRM=false
SOLANA_RPC_URL=https://api.devnet.solana.com
# Escrow keypair secret as a JSON array of bytes (devnet only). Generate with: node scripts/gen-escrow.mjs
# Fund it via https://faucet.solana.com before running payouts/refunds.
SOLANA_ESCROW_SECRET=